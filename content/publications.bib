@article{xie2023mf,
  title={MF-ANN: A novel artificial neural network-based method for ocean wind speed retrieval on spaceborne GNSS-R signal},
  author={Xie, Heng and Cheng, Xing and He, Shanbao and Li, Yujie and Pang, Jingjing and Li, Shuaishuai},
  journal={IEEE Transactions on Geoscience and Remote Sensing},
  volume={61},
  pages={1--17},
  year= {2023},
  month = nov,
  publisher={IEEE},
  abstract = {An artificial neural network (ANN) model-based method is proposed to retrieve the ocean surface wind speed from cyclone global navigation satellite system (CYGNSS) L1 observation data. The proposed method is embedded with an input features and output results filtering module based on a machine-learning (ML) algorithm, abbreviated as the MF-ANN method. By studying the relationship between physical observation variables from CYGNSS L1 data and the wind speed of the European Centre for Medium-Range Weather Forecast (ECMWF) reanalysis dataset and cross-calibrated multiplatform (CCMP) dataset, a feature parameter selection module based on the XGBoost algorithm and Pearson correlation coefficient is designed to automatically select the optimal combination of feature parameters related to the ocean surface wind speed and input the feature parameters into the ANN model. An outlier filtering module based on the unsupervised ML algorithm is designed to identify and eliminate the outliers in the wind speed data retrieved by the ANN model, reducing the errors that cannot be eliminated by the fixed threshold of the quality flag provided in the CYGNSS L1 product. The experiments show that the RMSEs of the MF-ANN model can be reduced by 11.73% and 15.31% compared with those of a single ANN model by adding feature selection modules and quality filtering modules, respectively. The RMSE of the MF-ANN model combining these two modules can be reduced by 29.08%.},
  preview={mfann.png},
  description={Application of an Improved Artificial Neural Network in Sea Surface Wind Speed Retrieval for CYGNSS Mission.},
  keywords={CYGNSS, GNSS-R, Machine Learning, NDBC, Wind speed retrieval},
  doi = {10.1109/TGRS.2023.3323679},
  selected = {true},
  langid = {english},
}

@inproceedings{xie2022convolution,
  title={A convolution neural network-based method for sea ice remote sensing using GNSS-R data},
  author={Xie, Heng and He, Shanbao and Cheng, Xing},
  booktitle={2022 4th International Conference on Communications, Information System and Computer Engineering (CISCE)},
  pages = {284--289},
  year = {2022},
  month = sep,
  publisher={IEEE},
  organization={IEEE},
  abstract ={Sea ice remote sensing is of great significance to the understanding of polar climate change. At present, the global navigation satellite system reflector (GNSS-R) technology has been applied to the study of sea ice remote sensing and achieved good results. In this paper, a convolution neural network (CNN) based method for sea ice recognition (SIR) and estimation of sea ice concentration (SIC) using GNSS-R data is proposed. Specifically, a CNN model is designed to solve the classification problem of SIR and the regression problem of SIC estimation. In the stage of data set construction, first, the global GNSS-R data (TDS-1), in a certain period of time, is spatiotemporally matched with the relatively reliable sea ice data (NSIDC), and then the matched GNSS-R data is extracted to balance the amount of seawater data and sea ice data. In the stage of CNN model construction, the feature learning ability of the model is enhanced by adding convolution layer, pooling layer and full connection layer. Simulation results show that the proposed CNN-based scheme has a higher prediction accuracy of SIR and lower estimation error of SIC than other existing methods.},
  keywords={GNSS, TDS-1, CNN, Remote Sensing},
  doi = {10.1109/CISCE55963.2022.9851159},
  selected = {true},
  langid = {english},
}


@inproceedings{cheng2023sea,
  title={A sea ice type recognition method based on convolutional neural network for GNSS-R delay Doppler images},
  author={Cheng, Xing and Xie, Heng and He, Shanbao},
  booktitle={2023 4th International Conference on Big Data \& Artificial Intelligence \& Software Engineering (ICBASE)},
  pages={103--107},
  year={2023},
  month = aug,
  publisher={IEEE},
  organization={IEEE},
  abstract ={Remote sensing (RS) of sea ice types is of great significance for global climate research. A convolutional neural network (CNN) based sea ice type recognition method for delay Doppler map (DDM) of global navigation satellite system reflection (GNSS-R) is proposed in this paper. In the proposed method, the sea ice type recognition problem is transformed into an image recognition problem by utilizing the difference between the DDM images corresponding to the first-year and multi-year ice, and the CNN model is used to recognize the images. Experimental results show that our proposed CNN based method for identifying sea ice types has excellent performance.},
  keywords ={convolutional neural network; image recognition; seaice; ocean remote sensing},
  doi = {10.1109/ICBASE59196.2023.10303203},
  selected = {true},
  langid = {english},
}



@article{li2025global,
  title={Global navigation satellite system reflectometry specular point positioning method based on reflection geometric model: suitable for land and ocean applications},
  author={Li, Shuaishuai and He, Shanbao and Cheng, Xing and Wang, Feng and Xie, Heng and Pang, Jingjing and Cai, Min},
  journal={Journal of Applied Remote Sensing},
  volume={19},
  number={1},
  pages={014512--014512},
  year={2025},
  month = jan,
  publisher={Society of Photo-Optical Instrumentation Engineers},
  abstract = {The accurate positioning of the specular point of the spaceborne global navigation satellite system reflectometry (GNSS-R) receiver is a key step in using GNSS-R technology for geophysical parameter retrieval. As GNSS-R applications expand across diverse environments ranging from land and oceans to glaciers, traditional geometric positioning accuracy is no longer sufficient to meet the demands of these varied applications. Specifically, positioning algorithms must not only facilitate real-time spaceborne processing but also adapt to fluctuating surface conditions, all while sustaining high levels of accuracy and efficiency. In response to these demands, we propose a positioning algorithm tailored for spaceborne GNSS-R specular points across various surface environments. The proposed algorithm integrates actual surface height data by leveraging surface models for localized terrain fitting. It employs a regional grid traversal method, guided by geographic positioning criteria, to accurately search for specular points that satisfy specific conditions. Considering the impact of initial position accuracy on traversal speed, we developed an ellipsoidal reflection geometric model based on the unique properties of the ellipsoid. This model facilitates the swift, non-iterative determination of a high-precision initial position for specular points. Experimental data indicate that our proposed approach reduces the Euclidean distance error of the initial position by ∼ 87.5 % and enhances grid traversal efficiency by a factor of more than eight times. To verify the robustness of the proposed method, this paper conducted multiple experiments in both ocean and land scenarios, including case studies in the Qinghai-Tibet Plateau region. The findings highlight that the normal vector angle analysis criterion offers superior reliability in complex terrains, positioning it as the optimal criterion for the positioning of specular points.},
  keywords={Satellites, Data modeling, Specular reflections},
  doi = {10.1117/1.JRS.19.014512},
  langid = {english},
}

@inproceedings{cai2024deep,
  title={A deep neural networks-based significant wave height inversion method for GNSS-R signals},
  author={Cai, Min and Cheng, Xing and He, Shanbao and Cui, Yinghua and Xie, Heng and Pang, Jingjing and Li, Shuaishuai},
  booktitle={2024 4th International Conference on Neural Networks, Information and Communication Engineering (NNICE)},
  pages={1208--1211},
  year={2024},
  publisher={IEEE},
  organization={IEEE},
  abstract ={Significant wave height (SWH), a crucial parameter in monitoring oceanic conditions, holds significant importance in the realms of wave forecasting, disaster preparedness, and risk mitigation. Compared with satellite altimetry and other technologies, the Global Navigation Satellite System-Reflectometry (GNSS-R) technology boasts distinctive advantages that set it apart. This paper has proposed a technique for extracting SWH from GNSS-R data, utilizing Deep Neural Networks (DNN). In the data preprocessing stage, model input parameters are extracted from the downloaded CYGNSS SWH data and ERA5 SWH data. After denoising and filtering the data, an appropriate spatiotemporal matching window is selected to obtain the matched CYGNSS data as the input for the model, with ERA5 data as the label. Choose DNN to handle the regression problem of SWH inversion. Finally, the SWH values inverted by the method proposed in this paper are compared and analyzed with the SWH values of ERA5 as labels. The outcomes demonstrate enhanced performance of the inversion method based on DNN, resulting in a reduced root mean square error (RMSE) and an improved correlation coefficient (CC). Specifically, the achieved RMSE falls below 0.55m, while the CC reaches 0.69. Additionally, this suggests that the presented inversion method demonstrates commendable performance.},
  keywords ={inversion, significant wave height, Cyclone GNSS, deep neural networks},
  doi = {10.1109/NNICE61279.2024.10498147},
  langid = {english},
}

@article{cai2026convolutional,
  title={Convolutional interactive learning network with auxiliary features for hypersonic glide vehicle trajectory prediction under data missing scenarios},
  author={Cai, Yuepeng and Zhuang, Xuebin and Zhong, Yuanfu and Xie, Heng},
  journal={Aerospace Science and Technology},
  pages={112222},
  year={2026},
  month = may,
  publisher={Elsevier},
  abstract = {The accurate positioning of the specular point of the spaceborne global navigation satellite system reflectometry (GNSS-R) receiver is a key step in using GNSS-R technology for geophysical parameter retrieval. As GNSS-R applications expand across diverse environments ranging from land and oceans to glaciers, traditional geometric positioning accuracy is no longer sufficient to meet the demands of these varied applications. Specifically, positioning algorithms must not only facilitate real-time spaceborne processing but also adapt to fluctuating surface conditions, all while sustaining high levels of accuracy and efficiency. In response to these demands, we propose a positioning algorithm tailored for spaceborne GNSS-R specular points across various surface environments. The proposed algorithm integrates actual surface height data by leveraging surface models for localized terrain fitting. It employs a regional grid traversal method, guided by geographic positioning criteria, to accurately search for specular points that satisfy specific conditions. Considering the impact of initial position accuracy on traversal speed, we developed an ellipsoidal reflection geometric model based on the unique properties of the ellipsoid. This model facilitates the swift, non-iterative determination of a high-precision initial position for specular points. Experimental data indicate that our proposed approach reduces the Euclidean distance error of the initial position by ∼ 87.5 % and enhances grid traversal efficiency by a factor of more than eight times. To verify the robustness of the proposed method, this paper conducted multiple experiments in both ocean and land scenarios, including case studies in the Qinghai-Tibet Plateau region. The findings highlight that the normal vector angle analysis criterion offers superior reliability in complex terrains, positioning it as the optimal criterion for the positioning of specular points.},
  keywords={Trajectory prediction, Hypersonic glide vehicle, Auxiliary features, Convolutional interactive learning network, Data missing},
  doi = {10.1016/j.ast.2026.112222},
  langid = {english},
}

@article{lin2026tda,
  title={TDA-M: A High Efficient Three-Dimensional Acquisition Algorithm for LeGNSS MCSK Signals},
  author={Lin, Zijun and Wang, Shuai and Zhuang, Xuebin and Wu, Cailun and Xie, Heng and Hong, Qihan},
  journal={IEEE Transactions on Vehicular Technology},
  year={2026},
  month = jan,
  publisher={IEEE},
  abstract = {Driven by the high data transmission requirement of low earth orbit enhanced global navigation satellite system (LeGNSS), multiplexed code shift keying (MCSK) has emerged as a novel modulation. The numerous satellites and the high dynamic variation in the LeGNSS constellation pose great challenges to the efficient acquisition of MCSK signals. We propose a high efficient three-dimensional acquisition algorithm for LeGNSS MCSK signals (TDA-M), searching for Doppler, primary code phase, and secondary code phase. Our scheme employs phase rotation code to enhance acquisition efficiency and utilizes the dynamic dual-layer partial matched filter with fast fourier transform to maintain high performance in the large dynamic regions. Numerical simulation results show that TDA-M is 17 times faster than existing scheme under the same code multiplexing level and Doppler search range. In high dynamic scenarios, the dynamic search factor improves secondary code phase estimation accuracy by up to 50% compared with the case without it, and the probability of Doppler estimation error falls within FFT spectral resolution exceeds 97%.},
  keywords={low earth orbit enhanced global navigation, satellite system(LeGNSS), multiplexed code shift keying(MCSK), efficient signal acquisition, high dynamic},
  doi ={10.1109/TVT.2026.3674126},
  langid = {english},
}





